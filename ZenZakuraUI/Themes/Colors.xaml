<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SakuraPink">#F2B4BC</Color>
    <Color x:Key="SakuraPinkLight">#F8D0D6</Color>
    <Color x:Key="SakuraPinkDark">#D48A94</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="WhiteSmoke">#F5F5F5</Color>
    <Color x:Key="LightGray">#E8E8E8</Color>
    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#666666</Color>
    <Color x:Key="TextPink">#F2B4BC</Color>

    <SolidColorBrush x:Key="SakuraPinkBrush" Color="#F2B4BC" />
    <SolidColorBrush x:Key="SakuraPinkLightBrush" Color="#F8D0D6" />
    <SolidColorBrush x:Key="SakuraPinkDarkBrush" Color="#D48A94" />
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="WhiteSmokeBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="LightGrayBrush" Color="#E8E8E8" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666" />
    <SolidColorBrush x:Key="TextPinkBrush" Color="#F2B4BC" />

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFF8F8" />
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFF0F2" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FCE4E8" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#F2B4BC" />
    <SolidColorBrush x:Key="SelectedItemBrush" Color="#FCE4E8" />
    <SolidColorBrush x:Key="BorderBrush" Color="#F0E0E2" />

    <FontFamily x:Key="FontPrimary">pack://font:families/Lexend Tera</FontFamily>
    <FontFamily x:Key="FontFallback">/Resources/#Lexend Tera</FontFamily>
</ResourceDictionary>
